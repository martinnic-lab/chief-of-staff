# ============================================================
# Plantilla de variables de entorno — copiá este archivo como
# .env.local y completá los valores reales.
# .env.local NUNCA se sube a GitHub (está en .gitignore).
# ============================================================

# --- Base de datos (Neon / PostgreSQL) ---
# La cadena de conexión que te da neon.tech (botón "Connect").
NEON_CONNECTION_STRING=postgresql://usuario:clave@host/neondb?sslmode=require

# --- Telegram (solo envío de avisos) ---
# Token del bot (te lo da @BotFather) y el chat al que avisa.
TELEGRAM_BOT_TOKEN=123456789:AAAA...
TELEGRAM_CHAT_ID=123456789

# --- Microsoft Graph / Planner ---
# Salen del registro de aplicación en Azure (ver RUNBOOK.md, paso a paso).
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# ID del plan de Planner a sincronizar (ver RUNBOOK.md cómo encontrarlo).
PLANNER_PLAN_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cada cuántos minutos sincronizar (opcional; por defecto 5).
# SYNC_INTERVAL_MIN=5

# --- Modo nube (Vercel) ---
# Secreto inventado (texto largo aleatorio) que valida que los mensajes del
# webhook de Telegram son auténticos. El mismo valor se usa en setWebhook.
TELEGRAM_WEBHOOK_SECRET=texto-aleatorio-largo
# Secreto inventado para el cron de atrasos de Vercel.
CRON_SECRET=otro-texto-aleatorio-largo
# Usuario y contraseña para entrar al tablero web (si la contraseña está
# vacía, el tablero queda abierto — solo recomendable en local).
DASHBOARD_USER=martin
DASHBOARD_PASSWORD=elegi-una-clave
